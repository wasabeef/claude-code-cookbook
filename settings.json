{
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "600000",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Glob",
      "Grep",
      "LS",
      "MultiEdit",
      "Read",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskUpdate",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(rm -fR *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(chown -R *)",
      "Bash(> /dev/sda *)",
      "Bash(format *)",
      "Bash(apt-get install *)",
      "Bash(brew install *)",
      "Bash(bundle install *)",
      "Bash(gem install *)",
      "Bash(npm install -g *)",
      "Bash(pip install *)",
      "Bash(yum install *)",
      "Bash(git checkout *)",
      "Bash(git clean *)",
      "Bash(git config *)",
      "Bash(git branch -D *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git restore *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh auth logout *)",
      "Bash(gh auth refresh *)",
      "Bash(gh gist create *)",
      "Bash(gh gist delete *)",
      "Bash(gh gpg-key add *)",
      "Bash(gh gpg-key delete *)",
      "Bash(gh release create *)",
      "Bash(gh release delete *)",
      "Bash(gh release upload *)",
      "Bash(gh repo archive *)",
      "Bash(gh repo clone *)",
      "Bash(gh repo create *)",
      "Bash(gh repo delete *)",
      "Bash(gh repo deploy-key *)",
      "Bash(gh repo edit *)",
      "Bash(gh repo fork *)",
      "Bash(gh repo rename *)",
      "Bash(gh repo sync *)",
      "Bash(gh repo unarchive *)",
      "Bash(gh secret delete *)",
      "Bash(gh secret set *)",
      "Bash(gh ssh-key add *)",
      "Bash(gh ssh-key delete *)",
      "Bash(gh workflow disable *)",
      "Bash(gh workflow enable *)",
      "Bash(gh workflow run *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/preserve-file-permissions.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/preserve-file-permissions.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.sh",
    "refreshInterval": 30
  }
}
